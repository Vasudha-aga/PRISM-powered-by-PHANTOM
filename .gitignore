# ==========================================================
# PRISM Powered by PHANTOM
# .gitignore
# ==========================================================

# ==========================================================
# NODE / NEXT.JS (Frontend)
# ==========================================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Package managers
frontend/package-lock.json.bak
frontend/yarn.lock.bak
frontend/pnpm-lock.yaml.bak

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================
# PYTHON / FASTAPI (Backend)
# ==========================================================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class

# Python Virtual Environments
backend/venv/
backend/.venv/
backend/env/
backend/ENV/

# FastAPI / Uvicorn
backend/*.log

# Environment variables
backend/.env
backend/.env.*
!backend/.env.example

# Testing / Type Checking / Linting
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.mypy_cache/
backend/.ruff_cache/

# Distribution / Packaging
backend/.Python
backend/build/
backend/dist/
backend/*.egg-info/
backend/*.egg

# ==========================================================
# IDES & EDITORS
# ==========================================================
.vscode/
.idea/
*.suo
*.sln
*.sw?
*.swp

# ==========================================================
# OPERATING SYSTEM FILES
# ==========================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==========================================================
# CACHE & TEMP FILES
# ==========================================================
.cache/
tmp/
temp/
*.tmp
*.temp

# ==========================================================
# UPLOADS / GENERATED FILES
# ==========================================================
uploads/
generated/
artifacts/

# Next.js cache
frontend/.turbo/

# Vercel
.vercel/

# Coverage reports
coverage/

# Python notebook checkpoints
.ipynb_checkpoints/

# Mac/Linux hidden files
.fseventsd

# Local uploads
backend/uploads/

# Generated AI outputs
backend/generated/

# Secrets
*.pem
*.key
*.crt